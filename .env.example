# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# SUPABASE_URL: The base URL of your Supabase project (e.g., https://your-project.supabase.co)
SUPABASE_URL=https://placeholder-project.supabase.co

# SUPABASE_KEY: The anon/public or service_role API key for your Supabase project
SUPABASE_KEY=your-supabase-api-key-placeholder
